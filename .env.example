# Spotify application client ID (public value from your Spotify developer dashboard).
# Copy this file to `.env.local` and fill in your own values.
VITE_SPOTIFY_CLIENT_ID=your_spotify_client_id_here

# Tidal — from https://developer.tidal.com (public, no secret needed for PKCE).
VITE_TIDAL_CLIENT_ID=

# Apple Music — a JWT generated by scripts/generate-apple-token.mjs.
# Max validity 180 days; regenerate periodically and rebuild.
# (Apple Music provider is currently disabled in src/providers/index.js.)
VITE_APPLE_MUSIC_DEV_TOKEN=

# --- Used ONLY by scripts/generate-apple-token.mjs, never bundled into the app.
# --- Keep the .p8 file OUTSIDE this repo.
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY_PATH=~/.secrets/AuthKey_XXXXXXXXXX.p8
